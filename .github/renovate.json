{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests"],
  "enabledManagers": ["gomod", "terraform", "custom.regex", "ocb", "github-actions"],
  "useBaseBranchConfig": "merge",
  "recreateWhen": "always",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "reviewers": ["cvdtang"],
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "pinDigests": true,
  "ignoreDeps": ["github.com/cvdtang/pkienginereceiver"],

  "ocb": {
    "managerFilePatterns": ["/(^|/)test\\/builder-config\\.ya?ml$/"]
  },

  "customManagers": [
    {
      "description": "Update OTel builder versions",
      "customType": "regex",
      "managerFilePatterns": ["/README\\.md/", "/justfile/"],
      "matchStrings": [
        "gomod:\\s*github\\.com/[^\\s]+\\s+(?<currentValue>v[^\\s]+)",
        "(?m)^TARGET_VERSION\\s*:=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "open-telemetry/opentelemetry-collector-releases",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^cmd/builder/v(?<version>.*)$"
    },
    {
      "description": "Update container images in integration_test.go",
      "customType": "regex",
      "managerFilePatterns": ["/integration_test\\.go/"],
      "matchStrings": [
        "(?m)^\\s*//\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\r?\\n\\s*\\w+\\s*=\\s*\"(?:[^\":]+:)?(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["terraform"],
      "groupName": "terraform providers"
    },
    {
      "matchManagers": ["gomod", "ocb"],
      "groupName": "otel",
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "matchManagers": ["ocb"],
      "pinDigests": false
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["open-telemetry/opentelemetry-collector-releases"],
      "groupName": "otel"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "minimumReleaseAge": "14 days"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": [
        "hashicorp/vault",
        "openbao/openbao",
        "rancher/k3s"
      ],
      "commitMessagePrefix": "test(integration): ",
      "commitMessageAction": "",
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "{{prettyNewVersion}}"
    }
  ]
}
