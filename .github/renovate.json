{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["helpers:pinGitHubActionDigests"],
  "enabledManagers": ["gomod", "terraform", "custom.regex", "ocb", "github-actions"],
  "useBaseBranchConfig": "merge",
  "recreateWhen": "always",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "reviewers": ["cvdtang"],
  "gitAuthor": "Renovate Bot <bot@renovateapp.com>",
  "pinDigests": true,
  "separateMajorMinor": false,
  "ignoreDeps": ["github.com/cvdtang/pkienginereceiver"],

  "ocb": {
    "managerFilePatterns": ["/(^|/)test\\/builder-config\\.ya?ml$/"]
  },

  "customManagers": [
    {
      "description": "Update gomod reference in README.md",
      "customType": "regex",
      "managerFilePatterns": ["/README\\.md/"],
      "matchStrings": [
        "gomod:\\s*github\\.com/cvdtang/pkienginereceiver\\s+v(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "open-telemetry/opentelemetry-collector",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "Update OTel builder version in justfile",
      "customType": "regex",
      "managerFilePatterns": ["/justfile/"],
      "matchStrings": [
        "(?m)^TARGET_VERSION\\s*:=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "open-telemetry/opentelemetry-collector",
      "versioningTemplate": "semver",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "Update container images in integration_test.go",
      "customType": "regex",
      "managerFilePatterns": ["/integration_test\\.go/"],
      "matchStrings": [
        "(?m)^\\s*//\\s*renovate:\\s*datasource=(?<datasource>\\S+)\\s+depName=(?<depName>\\S+)\\s*\\r?\\n\\s*\\w+\\s*=\\s*\"(?:[^\":]+:)?(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["terraform"],
      "groupName": "terraform providers",
      "commitMessagePrefix": "chore(deps):",
      "commitMessageAction": "upgrade",
      "commitMessageTopic": "terraform providers",
      "commitMessageExtra": ""
    },
    {
      "matchManagers": ["gomod", "ocb"],
      "groupName": "otel",
      "group": {
        "commitMessageTopic": ""
      },
      "postUpdateOptions": ["gomodTidy"],
      "commitMessagePrefix": "chore(release):",
      "commitMessageAction": "{{#each upgrades}}{{#if (equals depName 'go.opentelemetry.io/collector/scraper')}}{{newValue}}{{/if}}{{/each}}",
      "commitMessageTopic": "",
      "commitMessageExtra": ""
    },
    {
      "matchManagers": ["ocb"],
      "pinDigests": false
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": ["open-telemetry/opentelemetry-collector"],
      "groupName": "otel",
      "group": {
        "commitMessageTopic": ""
      },
      "commitMessagePrefix": "chore(release):",
      "commitMessageAction": "{{#each upgrades}}{{#if (equals depName 'go.opentelemetry.io/collector/scraper')}}{{newValue}}{{/if}}{{/each}}",
      "commitMessageTopic": "",
      "commitMessageExtra": ""
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "minimumReleaseAge": "14 days",
      "commitMessagePrefix": "chore(ci):",
      "commitMessageAction": "bump",
      "commitMessageTopic": "github actions",
      "commitMessageExtra": ""
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepNames": [
        "hashicorp/vault",
        "openbao/openbao",
        "rancher/k3s"
      ],
      "commitMessagePrefix": "test(integration):",
      "commitMessageAction": "",
      "commitMessageTopic": "{{depName}}",
      "commitMessageExtra": "{{prettyNewVersion}}"
    }
  ]
}
